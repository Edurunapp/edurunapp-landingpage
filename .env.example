# EmailJS Configuration
# Get these values from: https://dashboard.emailjs.com

# Service ID - From "Email Services" section
PUBLIC_EMAILJS_SERVICE_ID=your_service_id_here

# Template ID - From "Email Templates" section
PUBLIC_EMAILJS_TEMPLATE_ID=your_template_id_here

# Public Key - From "Account" > "General" > "Public Key"
PUBLIC_EMAILJS_PUBLIC_KEY=your_public_key_here
