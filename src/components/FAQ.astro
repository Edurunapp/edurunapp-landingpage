---
// src/components/FAQ.astro
import { getLangFromUrl, useTranslations } from '../i18n/utils';

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);
---
<section id="faq" class="py-24 bg-white">
  <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8">
    
    <div class="text-center mb-16">
      <div class="inline-flex items-center gap-2 bg-purple-100 border border-purple-200 rounded-full px-4 py-1.5 mb-6">
        <svg class="w-4 h-4 text-edurun-purple" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8.228 9c.549-1.165 2.03-2 3.772-2 2.21 0 4 1.343 4 3 0 1.4-1.278 2.575-3.006 2.907-.542.104-.994.54-.994 1.093m0 3h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/>
        </svg>
        <span class="text-sm font-medium text-edurun-purple tracking-wide">{t.faq.badge}</span>
      </div>
      
      <h2 class="text-3xl md:text-4xl font-bold text-edurun-dark mb-4">
        {t.faq.title}
      </h2>
      <p class="text-lg text-gray-600">
        {t.faq.subtitle}
      </p>
    </div>

    <div class="space-y-4">
      
      <!-- FAQ Item 1 -->
      <details class="group bg-gray-50 rounded-xl border border-gray-200 hover:border-edurun-blue/30 transition-all">
        <summary class="flex justify-between items-center cursor-pointer px-6 py-5 font-semibold text-gray-900 select-none list-none">
          <span class="text-lg">{t.faq.items.lti.question}</span>
          <svg class="w-5 h-5 text-gray-400 transition-transform group-open:rotate-180 flex-shrink-0 ml-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"/>
          </svg>
        </summary>
        <div class="px-6 pb-5 text-gray-600 leading-relaxed">
          <p set:html={t.faq.items.lti.answer}></p>
        </div>
      </details>

      <!-- FAQ Item 2 -->
      <details class="group bg-gray-50 rounded-xl border border-gray-200 hover:border-edurun-blue/30 transition-all">
        <summary class="flex justify-between items-center cursor-pointer px-6 py-5 font-semibold text-gray-900 select-none list-none">
          <span class="text-lg">{t.faq.items.ai.question}</span>
          <svg class="w-5 h-5 text-gray-400 transition-transform group-open:rotate-180 flex-shrink-0 ml-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"/>
          </svg>
        </summary>
        <div class="px-6 pb-5 text-gray-600 leading-relaxed">
          <p set:html={t.faq.items.ai.answer}></p>
        </div>
      </details>

      <!-- FAQ Item 3 -->
      <details class="group bg-gray-50 rounded-xl border border-gray-200 hover:border-edurun-blue/30 transition-all">
        <summary class="flex justify-between items-center cursor-pointer px-6 py-5 font-semibold text-gray-900 select-none list-none">
          <span class="text-lg">{t.faq.items.languages.question}</span>
          <svg class="w-5 h-5 text-gray-400 transition-transform group-open:rotate-180 flex-shrink-0 ml-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"/>
          </svg>
        </summary>
        <div class="px-6 pb-5 text-gray-600 leading-relaxed">
          <p>{t.faq.items.languages.answer}</p>
        </div>
      </details>

      <!-- FAQ Item 4 -->
      <details class="group bg-gray-50 rounded-xl border border-gray-200 hover:border-edurun-blue/30 transition-all">
        <summary class="flex justify-between items-center cursor-pointer px-6 py-5 font-semibold text-gray-900 select-none list-none">
          <span class="text-lg">{t.faq.items.security.question}</span>
          <svg class="w-5 h-5 text-gray-400 transition-transform group-open:rotate-180 flex-shrink-0 ml-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"/>
          </svg>
        </summary>
        <div class="px-6 pb-5 text-gray-600 leading-relaxed">
          <p set:html={t.faq.items.security.answer}></p>
        </div>
      </details>

      <!-- FAQ Item 5 -->
      <details class="group bg-gray-50 rounded-xl border border-gray-200 hover:border-edurun-blue/30 transition-all">
        <summary class="flex justify-between items-center cursor-pointer px-6 py-5 font-semibold text-gray-900 select-none list-none">
          <span class="text-lg">{t.faq.items.cloud.question}</span>
          <svg class="w-5 h-5 text-gray-400 transition-transform group-open:rotate-180 flex-shrink-0 ml-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"/>
          </svg>
        </summary>
        <div class="px-6 pb-5 text-gray-600 leading-relaxed">
          <p set:html={t.faq.items.cloud.answer}></p>
        </div>
      </details>

    </div>

    <div class="mt-12 text-center">
      <p class="text-gray-600 mb-4">{lang === 'en' ? "Can't find the answer you're looking for?" : "¿No encuentras la respuesta que buscas?"}</p>
      <a href={lang === 'en' ? '/en/contacto' : '/contacto'} class="inline-flex items-center gap-2 bg-edurun-dark text-white px-6 py-3 rounded-xl font-semibold hover:bg-gray-900 transition-all shadow-lg hover:shadow-xl">
        <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"/>
        </svg>
        {t.nav.contact}
      </a>
    </div>

  </div>
</section>

<style>
  details summary::-webkit-details-marker {
    display: none;
  }
  
  details[open] {
    @apply border-edurun-blue/50 bg-blue-50/30;
  }
</style>
