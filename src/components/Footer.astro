---
import { getLangFromUrl, useTranslations } from '../i18n/utils';

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);
const currentYear = new Date().getFullYear();
---

<footer class="bg-gray-50 border-t border-gray-100 pt-16 pb-8">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="grid md:grid-cols-2 gap-12 mb-12">
      
      <div>
        <div class="flex items-center gap-2 mb-4">
          <img src="/logo.png" alt="Edurun Logo" class="h-8 w-auto grayscale opacity-50" />
          <span class="text-xl font-bold text-gray-900">Edurun</span>
        </div>
        <p class="text-gray-500 max-w-sm mb-6">
          {t.footer.description}
        </p>
      </div>

      <div class="grid grid-cols-2 gap-8">
        <div>
          <h3 class="font-semibold text-gray-900 mb-4">{t.nav.contact}</h3>
          <ul class="space-y-3 text-sm text-gray-600">
            <li>
              <a href={lang === 'en' ? '/en/contacto' : '/contacto'} class="hover:text-edurun-blue transition">{lang === 'en' ? 'Contact form' : 'Formulario de contacto'}</a>
            </li>
          </ul>
        </div>

        <div>
          <h3 class="font-semibold text-gray-900 mb-4">{t.footer.resources}</h3>
          <ul class="space-y-3 text-sm text-gray-600">
            <li><a href="/docs/guia-docente" class="hover:text-edurun-blue transition">{t.nav.docs}</a></li>
            <li><a href="https://github.com/Edurunapp" target="_blank" class="hover:text-edurun-blue transition">GitHub</a></li>
          </ul>
        </div>
      </div>

    </div>

    <div class="pt-8 border-t border-gray-200 flex flex-col md:flex-row justify-between items-center gap-4">
      <p class="text-sm text-gray-500">
        &copy; {currentYear} Edurun. {t.footer.rights}
      </p>
    </div>
  </div>
</footer>