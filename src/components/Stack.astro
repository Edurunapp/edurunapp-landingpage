---
// src/components/Stack.astro
---

<section class="py-16 border-t border-gray-100 bg-white">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <p class="text-center text-sm font-semibold text-gray-500 uppercase tracking-wider mb-8">
      Potenciado por tecnología moderna
    </p>
    <div class="grid grid-cols-2 md:grid-cols-5 gap-8 items-center">
      
      <div class="flex flex-col items-center justify-center gap-3 group cursor-default">
        <img src="https://cdn.jsdelivr.net/gh/homarr-labs/dashboard-icons/svg/canvas-lms.svg" alt="Canvas LMS" class="w-12 h-12 grayscale group-hover:grayscale-0 transition-all" />
        <span class="text-sm font-medium text-gray-600 group-hover:text-gray-900 transition-colors">Canvas LMS</span>
      </div>

      <div class="flex flex-col items-center justify-center gap-3 group cursor-default">
        <img src="https://cdn.jsdelivr.net/gh/devicons/devicon/icons/docker/docker-original.svg" alt="Docker" class="w-12 h-12 grayscale group-hover:grayscale-0 transition-all" />
        <span class="text-sm font-medium text-gray-600 group-hover:text-gray-900 transition-colors">Docker</span>
      </div>

      <div class="flex flex-col items-center justify-center gap-3 group cursor-default">
        <img src="https://cdn.jsdelivr.net/gh/devicons/devicon/icons/python/python-original.svg" alt="Python" class="w-12 h-12 grayscale group-hover:grayscale-0 transition-all" />
        <span class="text-sm font-medium text-gray-600 group-hover:text-gray-900 transition-colors">Python</span>
      </div>

      <div class="flex flex-col items-center justify-center gap-3 group cursor-default">
        <img src="https://cdn.jsdelivr.net/gh/devicons/devicon/icons/fastapi/fastapi-original.svg" alt="FastAPI" class="w-12 h-12 grayscale group-hover:grayscale-0 transition-all" />
        <span class="text-sm font-medium text-gray-600 group-hover:text-gray-900 transition-colors">FastAPI</span>
      </div>

      <div class="flex flex-col items-center justify-center gap-3 group cursor-default">
        <img src="https://cdn.jsdelivr.net/gh/devicons/devicon/icons/vuejs/vuejs-original.svg" alt="Vue.js" class="w-12 h-12 grayscale group-hover:grayscale-0 transition-all" />
        <span class="text-sm font-medium text-gray-600 group-hover:text-gray-900 transition-colors">Vue.js</span>
      </div>

    </div>
  </div>
</section>