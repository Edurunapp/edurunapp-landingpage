---
// src/components/LanguageSelector.astro
import { getLangFromUrl, getAlternateUrl } from '../i18n/utils';

const currentLang = getLangFromUrl(Astro.url);
const currentPath = Astro.url.pathname;

// Calculate the target language (opposite of current)
const targetLang = currentLang === 'es' ? 'en' : 'es';
const targetUrl = getAlternateUrl(currentPath, targetLang);
---

<a 
  href={targetUrl}
  data-astro-reload
  class="flex items-center gap-2 px-3 py-2 rounded-lg hover:bg-gray-100 dark:hover:bg-gray-800 transition-all cursor-pointer text-gray-700 dark:text-gray-300 font-medium border border-gray-200 dark:border-gray-700 hover:border-edurun-blue dark:hover:border-edurun-blue"
  aria-label={`Switch to ${targetLang === 'es' ? 'Español' : 'English'}`}
  title={targetLang === 'es' ? 'Cambiar a Español' : 'Switch to English'}
>
  {currentLang === 'es' ? (
    <>
      <!-- Spanish Flag SVG -->
      <svg class="w-6 h-4" viewBox="0 0 900 600" xmlns="http://www.w3.org/2000/svg">
        <rect width="900" height="600" fill="#c60b1e"/>
        <rect width="900" height="300" y="150" fill="#ffc400"/>
      </svg>
      <span class="text-sm font-semibold">ES</span>
    </>
  ) : (
    <>
      <!-- US Flag SVG -->
      <svg class="w-6 h-4" viewBox="0 0 7410 3900" xmlns="http://www.w3.org/2000/svg">
        <rect width="7410" height="3900" fill="#b22234"/>
        <path d="M 0,450 h 7410 m 0,600 H 0 m 0,600 h 7410 m 0,600 H 0 m 0,600 h 7410 m 0,600 H 0" stroke="#fff" stroke-width="300"/>
        <rect width="2964" height="2100" fill="#3c3b6e"/>
      </svg>
      <span class="text-sm font-semibold">EN</span>
    </>
  )}
</a>
