---
import Layout from '../layouts/Layout.astro';
import Navbar from '../components/Navbar.astro';
import Footer from '../components/Footer.astro';
---

<Layout title="Página no encontrada | Edurun">
  <Navbar />
  
  <div class="min-h-screen flex items-center justify-center bg-gradient-to-br from-gray-50 via-blue-50/30 to-purple-50/30 px-4 py-20">
    <div class="max-w-2xl mx-auto text-center">
      
      <!-- Animated 404 -->
      <div class="mb-8">
        <h1 class="text-9xl md:text-[12rem] font-extrabold text-transparent bg-clip-text bg-gradient-to-r from-edurun-blue via-purple-500 to-edurun-purple animate-gradient leading-none">
          404
        </h1>
      </div>

      <!-- Content -->
      <div class="space-y-4 mb-10">
        <h2 class="text-3xl md:text-4xl font-bold text-edurun-dark">
          Página no encontrada
        </h2>
        <p class="text-lg text-gray-600 max-w-md mx-auto">
          Lo sentimos, la página que buscas no existe o ha sido movida. Pero no te preocupes, podemos ayudarte a encontrar lo que necesitas.
        </p>
      </div>

      <!-- Illustration (simple geometric shapes) -->
      <div class="mb-10 relative">
        <div class="inline-flex items-center justify-center">
          <div class="relative">
            <div class="absolute -top-4 -left-4 w-24 h-24 bg-edurun-blue/20 rounded-full blur-2xl morph-blob"></div>
            <div class="absolute -bottom-4 -right-4 w-32 h-32 bg-edurun-purple/20 rounded-full blur-2xl morph-blob" style="animation-delay: 2s;"></div>
            <svg class="w-48 h-48 text-gray-300 relative z-10" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M9.172 16.172a4 4 0 015.656 0M9 10h.01M15 10h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/>
            </svg>
          </div>
        </div>
      </div>

      <!-- Action Buttons -->
      <div class="flex flex-col sm:flex-row gap-4 justify-center items-center">
        <a 
          href="/" 
          class="inline-flex items-center gap-2 bg-edurun-dark text-white px-6 py-3 rounded-xl font-semibold hover:bg-gray-900 transition-all shadow-lg hover:shadow-xl">
          <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 12l2-2m0 0l7-7 7 7M5 10v10a1 1 0 001 1h3m10-11l2 2m-2-2v10a1 1 0 01-1 1h-3m-6 0a1 1 0 001-1v-4a1 1 0 011-1h2a1 1 0 011 1v4a1 1 0 001 1m-6 0h6"/>
          </svg>
          Volver al inicio
        </a>
        
        <a 
          href="/docs/arquitectura" 
          data-astro-reload
          class="inline-flex items-center gap-2 bg-white text-edurun-dark border-2 border-gray-200 px-6 py-3 rounded-xl font-semibold hover:border-edurun-blue hover:text-edurun-blue transition-all">
          <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 6.253v13m0-13C10.832 5.477 9.246 5 7.5 5S4.168 5.477 3 6.253v13C4.168 18.477 5.754 18 7.5 18s3.332.477 4.5 1.253m0-13C13.168 5.477 14.754 5 16.5 5c1.747 0 3.332.477 4.5 1.253v13C19.832 18.477 18.247 18 16.5 18c-1.746 0-3.332.477-4.5 1.253"/>
          </svg>
          Ver documentación
        </a>
      </div>

      <!-- Search suggestion -->
      <div class="mt-12 pt-8 border-t border-gray-200">
        <p class="text-sm text-gray-500 mb-4">Enlaces útiles:</p>
        <div class="flex flex-wrap gap-3 justify-center">
          <a href="/#funcionalidades" class="text-sm text-edurun-blue hover:underline">Funcionalidades</a>
          <span class="text-gray-300">•</span>
          <a href="/#integridad" class="text-sm text-edurun-blue hover:underline">Integridad</a>
          <span class="text-gray-300">•</span>
          <a href="/contacto" class="text-sm text-edurun-blue hover:underline">Contacto</a>
          <span class="text-gray-300">•</span>
          <a href="/docs/guia-docente" data-astro-reload class="text-sm text-edurun-blue hover:underline">Guía Docente</a>
        </div>
      </div>

    </div>
  </div>
  
  <Footer />
</Layout>

<style>
  /* Background gradient animation */
  @keyframes gradient-shift {
    0%, 100% { background-position: 0% 50%; }
    50% { background-position: 100% 50%; }
  }
  
  .animate-gradient {
    background-size: 200% 200%;
    animation: gradient-shift 5s ease infinite;
  }
</style>
